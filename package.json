{
  "name": "flipcast",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @flipcast/server-db db:generate",
    "db:migrate": "pnpm --filter @flipcast/server-db db:migrate",
    "db:push": "pnpm --filter @flipcast/server-db db:push"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
