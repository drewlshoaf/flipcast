# PostgreSQL
POSTGRES_USER=flipcast
POSTGRES_PASSWORD=flipcast
POSTGRES_DB=flipcast
POSTGRES_PORT=5432

# Redis (BullMQ broker + SSE pub/sub)
REDIS_PORT=6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
FLIPCAST_BUCKET=flipcast-audio
# Public URL that the browser uses to fetch stored audio
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Web app
WEB_PORT=3000

# Worker
WORKER_CONCURRENCY=2

# Default speaker speed for Flipcast generation (0.7 = slower, 1.0 = normal, 1.2 = faster).
# Can be overridden per-Flipcast via the slider on the form.
FLIPCAST_DEFAULT_SPEED=1.0

# Optional: set to enable real transcript generation. Leave blank to use the stub transcript.
ANTHROPIC_API_KEY=

# AWS (Polly TTS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ELEVENLABS_API_KEY=